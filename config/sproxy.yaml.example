# ==============================================================================
# sproxy.yaml — s-proxy 服务端配置示例（primary / 单机模式）
#
# 用途：部署在公司服务器，验证用户 JWT，管理配额，转发请求到 LLM API，
#       统计 token 用量，提供 Web Dashboard 和 Admin API。
#
# 部署模式：
#   单机模式 — 只有一台 s-proxy，cluster.role 设为 "primary"（默认）
#   集群模式 — 多台 s-proxy：一台 primary（sp-1）+ 若干 worker（sp-2, sp-3...）
#              本文件为 primary 配置；worker 配置见 sproxy-worker.yaml.example
#
# 使用方式：
#   sproxy start --config /path/to/sproxy.yaml
#
# 必须设置的环境变量（在 shell 或 systemd 中配置）：
#   ANTHROPIC_API_KEY_1  — 第一个 Anthropic API Key
#   ANTHROPIC_API_KEY_2  — 第二个 Anthropic API Key（可选，多 key 时用）
#   JWT_SECRET           — 用于签发/验证用户 JWT 的密钥（建议 32+ 字符随机字符串）
#   ADMIN_PASSWORD_HASH  — admin 面板密码的 bcrypt hash
#                          生成命令：sproxy admin hash-password
#   CLUSTER_SECRET       — 集群内部 API 的共享密钥（primary ↔ worker 通信鉴权）
#                          仅在多节点集群部署时必须；单机模式可留空
#                          生成示例：openssl rand -hex 32
# ==============================================================================


# ------------------------------------------------------------------------------
# listen — 监听地址
# ------------------------------------------------------------------------------
listen:
  host: "0.0.0.0"   # 对外监听（内网部署时可改为内网 IP）
  port: 9000


# ------------------------------------------------------------------------------
# llm — 上游 LLM API 配置
# ------------------------------------------------------------------------------
llm:
  # lb_strategy: 对 LLM 目标节点的负载均衡策略
  # 可选：round_robin（默认）| random | weighted
  lb_strategy: "round_robin"

  # request_timeout: 转发给 LLM 的请求超时（含流式响应）
  request_timeout: 300s

  # targets: 上游 LLM 节点列表
  # 支持多 API Key 轮询（同一 API Endpoint 配置多条，轮换使用不同 key）
  # provider: 指定 LLM provider（影响 token 解析方式和路由匹配）
  #   "anthropic"（默认）— Anthropic Claude API（/v1/messages）
  #   "openai"           — OpenAI Chat Completions API（/v1/chat/completions）
  #   "ollama"           — Ollama 本地推理服务（与 OpenAI 格式兼容）
  #
  # 多 Provider 支持：sproxy 根据请求路径自动路由到对应 provider 的 target
  #   /v1/messages         → 路由到 provider: anthropic 的 target
  #   /v1/chat/completions → 路由到 provider: openai 的 target
  #
  # ── 健康检查说明（智能探活） ──────────────────────────────────────────────
  #
  # sproxy 默认为每个 target 自动发现最合适的健康检查方式（智能探活）：
  #
  #   第一次检查时按 provider 类型依次尝试以下策略，找到第一个有效的后缓存（默认 2h）：
  #
  #   【通用 target（provider 非 anthropic）】
  #     1. GET /health             → 200 视为健康（适合 vLLM/sglang/自建代理）
  #     2. GET /v1/models          → 200/401/403 均视为"服务在线"（适合 OpenAI 兼容）
  #     3. POST /v1/chat/completions → 200/401/403/400 均视为"服务在线"（通用兜底）
  #
  #   【Anthropic provider（provider: "anthropic"）】专属策略优先
  #     1. GET /v1/models          → 200/401/403/400（含华为云 400 空 auth）
  #     2. POST /v1/messages       → 200/401/403/400
  #     3. GET /health             → 200（通用兜底）
  #     4. GET /v1/models          → 200/401/403（通用）
  #     5. POST /v1/chat/completions → 200/401/403/400（通用）
  #
  #   重要：发现阶段 401/403 仅表示"端点存在"；正式心跳时 401 仍视为 key 无效→失败
  #
  # 若您已知目标的健康检查路径，可以通过 health_check_path 显式指定，跳过自动探测：
  #   health_check_path: "/health"      # 直接使用，不走自动探测
  #   health_check_path: "/v1/models"   # 对 Anthropic/OpenAI 适用
  #
  # 各厂商推荐配置（无需手动指定，智能探活会自动发现）：
  #   Anthropic API        → 自动发现 GET /v1/models
  #   OpenAI API           → 自动发现 GET /v1/models
  #   火山引擎 Ark         → 自动发现 GET /v1/models
  #   腾讯 LKEAP           → 自动发现 GET /v1/models（OpenAI）/ POST /v1/messages（Anthropic）
  #   华为云 ModelArts     → 自动发现 GET /v1/models（key 无效时 401，仍视为端点存在）
  #   小米 MiMo            → 自动发现 GET /v1/models
  #   vLLM / sglang        → 自动发现 GET /health（无需配置 key）
  #   Ollama               → 自动发现 GET /health
  # ─────────────────────────────────────────────────────────────────────────
  targets:
    - url: "https://api.anthropic.com"
      api_key: "${ANTHROPIC_API_KEY_1}"   # 从环境变量读取，不要明文写 key
      weight: 1
      provider: "anthropic"               # 可省略，默认即为 anthropic
      # health_check_path 留空（或不填）→ 智能探活自动发现 GET /v1/models

    - url: "https://api.anthropic.com"
      api_key: "${ANTHROPIC_API_KEY_2}"
      weight: 1
      provider: "anthropic"

    # 示例：接入 OpenAI API（支持 Cursor、Continue.dev 等 OpenAI 格式客户端）
    # - url: "https://api.openai.com"
    #   api_key: "${OPENAI_API_KEY}"
    #   weight: 1
    #   provider: "openai"
    #   name: "OpenAI GPT"                # 可选显示名（Dashboard 展示）
    #   # 智能探活会自动发现 GET /v1/models，无需手动配置 health_check_path

    # 示例：接入 Ollama 本地推理（与 OpenAI 格式兼容）
    # - url: "http://localhost:11434"
    #   api_key: "ollama"                 # Ollama 不需要真实 key，随意填写
    #   weight: 1
    #   provider: "ollama"
    #   # 智能探活会自动发现 GET /health

    # 示例：接入其他兼容 Anthropic API 的服务（如 AWS Bedrock 中转层）
    # - url: "https://bedrock-proxy.company.com"
    #   api_key: "${BEDROCK_API_KEY}"
    #   weight: 2   # 权重更高，分配更多流量
    #   provider: "anthropic"

    # 示例：火山引擎 Ark（OpenAI 兼容）
    # - url: "https://ark.cn-beijing.volces.com/api/v3"
    #   api_key: "${ARK_API_KEY}"
    #   weight: 1
    #   provider: "openai"
    #   # 智能探活发现 GET /v1/models（200 表示健康）

    # 示例：华为云 ModelArts / MaaS（OpenAI 兼容）
    # - url: "https://api.modelarts-maas.com/openai/v1"
    #   api_key: "${HUAWEI_API_KEY}"
    #   weight: 1
    #   provider: "openai"
    #   # 智能探活发现 GET /v1/models（401 仅表示端点存在，key 有效时返回 200）

    # 示例：腾讯 LKEAP（Anthropic 兼容）
    # - url: "https://api.lkeap.cloud.tencent.com/v1"
    #   api_key: "${TENCENT_API_KEY}"
    #   weight: 1
    #   provider: "anthropic"
    #   # 智能探活发现 POST /v1/messages

    # 示例：带模型过滤的 target（仅路由指定模型的请求到此 target）
    # - url: "https://api.anthropic.com"
    #   api_key: "${ANTHROPIC_API_KEY}"
    #   provider: "anthropic"
    #   weight: 2
    #   supported_models:                    # 该 target 支持的模型列表（支持通配符，空=支持所有）
    #     - "claude-sonnet-4-*"
    #     - "claude-opus-4-*"
    #   auto_model: "claude-sonnet-4-20250514"  # auto 模式下使用的模型名

    # 示例：带模型过滤的 OpenAI target
    # - url: "https://api.openai.com"
    #   api_key: "${OPENAI_API_KEY}"
    #   provider: "openai"
    #   weight: 1
    #   supported_models:
    #     - "gpt-4o"
    #     - "gpt-4o-mini"
    #   auto_model: "gpt-4o"


# ------------------------------------------------------------------------------
# database — 数据库配置（支持 SQLite 和 PostgreSQL）
# ------------------------------------------------------------------------------
database:
  # driver: 数据库驱动，"sqlite"（默认）或 "postgres"
  # 省略时默认为 sqlite，向后兼容
  driver: "sqlite"

  # ── SQLite 配置（driver=sqlite 时使用）─────────────────────────────────────
  # path: SQLite 文件路径（绝对路径或相对于启动目录）
  path: "/var/lib/pairproxy/pairproxy.db"
  # path: "./pairproxy.db"   # 简单部署时用相对路径

  # ── PostgreSQL 配置（driver=postgres 时使用，取消下方注释并删除 path 字段）──
  # driver: "postgres"
  #
  # 方案A - 完整 DSN（推荐，方便注入 secret）：
  # dsn: "${DATABASE_URL}"
  # 方案B - 独立字段（若 DSN 为空则从这些字段拼接）：
  # host: "postgres.company.com"
  # port: 5432
  # user: "pairproxy"
  # password: "${DB_PASSWORD}"
  # dbname: "pairproxy"
  # sslmode: "require"    # disable | require | verify-full

  # ── 连接池（SQLite & PostgreSQL 通用）──────────────────────────────────────
  # write_buffer_size: 异步写入缓冲区大小（条）
  # 达到此数量时立即批量写入 DB，否则等到 flush_interval
  write_buffer_size: 200

  # flush_interval: 强制 flush 间隔（即使 buffer 未满也写入）
  flush_interval: 5s

  # max_open_conns: 最大连接数
  # PostgreSQL 建议 50（利用 MVCC 高并发）
  # SQLite 建议 25（WAL 模式上限）
  # 0 = 使用内置默认值
  # max_open_conns: 25


# ------------------------------------------------------------------------------
# auth — JWT 认证配置
# ------------------------------------------------------------------------------
auth:
  # jwt_secret: 签发和验证 JWT 的密钥
  # 必须保密！建议使用环境变量注入
  # 生成示例：openssl rand -hex 32
  jwt_secret: "${JWT_SECRET}"

  # keygen_secret: API Key HMAC 签名密钥（v2.15.0 新增必填项）
  # 用于生成和验证 sk-pp- 格式的 Direct Proxy API Key
  # 必须保密！建议使用环境变量注入，至少 32 字符
  # 生成示例：openssl rand -base64 32
  keygen_secret: "${KEYGEN_SECRET}"

  # access_token_ttl: access token 有效期（用户需在此期内刷新）
  access_token_ttl: 24h

  # refresh_token_ttl: refresh token 有效期（过期需重新登录）
  refresh_token_ttl: 168h   # 7 天

  # provider: 认证提供者，"local"（默认）或 "ldap"
  # - local：使用本地数据库验证用户名/密码
  # - ldap：通过 LDAP 服务器验证，首次登录自动创建用户（JIT 配置）
  # provider: "local"

  # ldap — LDAP 配置（provider: "ldap" 时生效）
  # ldap:
  #   server_addr: "ldap.example.com:389"   # LDAP 服务器地址（host:port）
  #   base_dn: "dc=example,dc=com"           # 搜索根 DN
  #   bind_dn: "cn=service,dc=example,dc=com" # 服务账户 DN（空=匿名绑定）
  #   bind_password: "${LDAP_BIND_PASSWORD}" # 服务账户密码
  #   user_filter: "(uid=%s)"               # 用户搜索过滤器（%s 替换为用户名）
  #   use_tls: false                          # true 使用 LDAPS（端口 636）


# ------------------------------------------------------------------------------
# admin — 管理员配置
# ------------------------------------------------------------------------------
admin:
  # password_hash: admin 面板登录密码的 bcrypt hash
  # 生成方式（交互式）：sproxy admin hash-password
  # 生成方式（非交互）：sproxy admin hash-password --password "your-password"
  password_hash: "${ADMIN_PASSWORD_HASH}"


# ------------------------------------------------------------------------------
# cluster — 集群配置
# ------------------------------------------------------------------------------
cluster:
  # role: 本节点角色
  # "primary"（默认）— sp-1，管理路由表，接受 worker 注册，提供 Dashboard
  # "worker"        — sp-2/sp-3...，定期向 primary 上报心跳和用量
  role: "primary"

  # self_addr: 本节点对外可达地址（其他节点用于连接本节点）
  # primary 节点的 self_addr 会被 worker 写入路由表分发给 c-proxy
  # 留空则不参与集群路由分发（单机部署时可留空）
  self_addr: "http://sp1.company.com:9000"

  # self_weight: 本节点在 c-proxy 负载均衡中的权重（1~100）
  # 性能强的节点可设高权重
  self_weight: 50

  # alert_threshold: active_req（并发请求数）超过此值时触发告警
  alert_threshold: 80

  # alert_webhook: 告警 Webhook URL（POST JSON）
  # 支持 Slack / 飞书 / 企业微信 / 自定义 HTTP endpoint
  # 留空则不发告警
  alert_webhook: ""
  # alert_webhook: "https://hooks.slack.com/services/xxx/yyy/zzz"
  # alert_webhook: "https://open.feishu.cn/open-apis/bot/v2/hook/xxx"

  # peer_monitor_interval: primary 驱逐超时 worker 节点的检查间隔
  peer_monitor_interval: 30s

  # report_interval: worker 向 primary 上报心跳+用量的间隔（仅 worker 使用）
  # primary 节点此字段无效
  report_interval: 30s

  # shared_secret: 集群内部 API 的 Bearer token（primary ↔ worker 通信鉴权）
  #
  # 安全策略（fail-closed）：
  #   - 为空时，primary 拒绝所有 /api/internal/* 请求（不存在"无鉴权"模式）
  #   - 单机部署时可留空（无 worker 注册，internal API 永远用不到）
  #   - 集群部署时**必须**设置为非空值，且 primary 和所有 worker 必须使用相同密钥
  #
  # 生成示例：openssl rand -hex 32
  shared_secret: "${CLUSTER_SECRET}"
  # shared_secret: ""   # 单机部署时留空即可

  # ---- 改进项2：worker 用量缓冲配置 ----
  usage_buffer:
    # enabled: 是否启用 worker 本地用量缓冲（默认 true）
    # 启用后，worker 将用量记录写入本地 DB，并在每次心跳时批量上报给 primary
    enabled: true
    # max_records_per_batch: 每批最多上报的记录数（默认 1000）
    max_records_per_batch: 1000


# ------------------------------------------------------------------------------
# dashboard — Web Dashboard 配置
# ------------------------------------------------------------------------------
dashboard:
  # enabled: 是否启用 Web Dashboard（访问 http://<server>:9000/dashboard/）
  # primary 节点默认启用；worker 节点默认不启用
  enabled: true


# ------------------------------------------------------------------------------
# pricing — 模型定价配置（用于估算请求费用，展示在 Dashboard）
# ------------------------------------------------------------------------------
pricing:
  # default_input_per_1k: 未匹配模型的默认输入 token 定价（USD / 1K tokens）
  # default_output_per_1k: 未匹配模型的默认输出 token 定价（USD / 1K tokens）
  default_input_per_1k: 0.003    # $3 / 1M tokens
  default_output_per_1k: 0.015   # $15 / 1M tokens

  # models: 按模型名称自定义定价（覆盖默认值）
  # key 为 Anthropic 返回的完整模型 ID（区分大小写）
  models:
    claude-opus-4-5:
      input_per_1k: 0.015    # $15 / 1M tokens
      output_per_1k: 0.075   # $75 / 1M tokens

    claude-sonnet-4-5:
      input_per_1k: 0.003
      output_per_1k: 0.015

    claude-haiku-4-5-20251001:
      input_per_1k: 0.0008   # $0.80 / 1M tokens
      output_per_1k: 0.004   # $4 / 1M tokens

    claude-3-5-sonnet-20241022:
      input_per_1k: 0.003
      output_per_1k: 0.015

    claude-3-5-haiku-20241022:
      input_per_1k: 0.0008
      output_per_1k: 0.004

    claude-3-opus-20240229:
      input_per_1k: 0.015
      output_per_1k: 0.075


# ------------------------------------------------------------------------------
# telemetry — OpenTelemetry 分布式追踪配置（F-7）
# ------------------------------------------------------------------------------
# telemetry:
#   enabled: false              # 默认禁用（零开销）
#   otlp_protocol: "grpc"       # "grpc"（默认）| "http" | "stdout"（调试用）
#   otlp_endpoint: ""           # OTLP 接收端地址，如 "http://jaeger:4317"（gRPC）
#                               #                    "http://jaeger:4318"（HTTP）
#   service_name: "pairproxy"   # 显示在追踪后端中的服务名
#   sampling_rate: 1.0          # 采样率，0.0~1.0（1.0=全量采样）

# ------------------------------------------------------------------------------
# log — 日志配置
# ------------------------------------------------------------------------------
log:
  # level: 日志级别
  # 可选：debug | info | warn | error
  # 生产环境建议 info；排查 token 统计问题时用 debug
  level: "info"

  # debug_file: 双向转发内容 debug 日志文件路径（可选，默认不启用）
  # 启用后，每条请求的四个方向（← 客户端请求、→ LLM 请求、← LLM 响应、← LLM chunk）
  # 均以 DEBUG 级别写入该文件，敏感 header 自动过滤，body 截断至 64 KB。
  # 支持 SIGHUP 热重载：修改此行后发送 kill -HUP <pid> 立即生效，无需重启。
  # debug_file: "/var/log/pairproxy/debug.log"


# ------------------------------------------------------------------------------
# track — 用户对话跟踪配置
# ------------------------------------------------------------------------------
# track:
#   dir: "./track"
#   # 对话跟踪数据的根目录。
#   # SQLite 模式：默认为 <database.path 所在目录>/track，无需配置。
#   # Peer/PostgreSQL 模式：database.path 为空，默认退化为 ./track（相对于进程工作目录）。
#   # 建议在 peer 模式下显式设置绝对路径，避免因工作目录不同导致路径不一致：
#   #   dir: "/data/pairproxy/track"
